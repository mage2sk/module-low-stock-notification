<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Panth\LowStockNotification\Block\Adminhtml\Alert\Edit" name="alert_edit" template="Panth_LowStockNotification::alert/view.phtml">
                <block class="Magento\Backend\Block\Widget\Button" name="back_button">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Back</argument>
                        <argument name="onclick" xsi:type="string">setLocation(window.location.href = '</argument>
                        <argument name="class" xsi:type="string">back</argument>
                    </arguments>
                </block>
                <block class="Magento\Backend\Block\Widget\Button" name="delete_button">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Delete</argument>
                        <argument name="class" xsi:type="string">delete</argument>
                    </arguments>
                </block>
                <block class="Magento\Backend\Block\Widget\Button" name="send_button">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Send Email</argument>
                        <argument name="class" xsi:type="string">action-secondary</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
