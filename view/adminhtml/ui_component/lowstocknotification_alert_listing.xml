<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">lowstocknotification_alert_listing.lowstocknotification_alert_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="back">
                <url path="lowstocknotification/dashboard/index"/>
                <class>back</class>
                <label translate="true">Back to Dashboard</label>
            </button>
        </buttons>
        <spinner>lowstocknotification_alert_columns</spinner>
        <deps>
            <dep>lowstocknotification_alert_listing.lowstocknotification_alert_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="lowstocknotification_alert_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">alert_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_LowStockNotification::alerts</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="lowstocknotification_alert_listing_data_source">
            <settings>
                <requestFieldName>alert_id</requestFieldName>
                <primaryFieldName>alert_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <settings>
                <templates>
                    <filters>
                        <select>
                            <param name="template" xsi:type="string">ui/grid/filters/elements/ui-select</param>
                            <param name="component" xsi:type="string">Magento_Ui/js/form/element/ui-select</param>
                        </select>
                    </filters>
                </templates>
            </settings>
        </filters>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected items?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="lowstocknotification/alert/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="send">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to send emails for selected alerts?</message>
                        <title translate="true">Send Emails</title>
                    </confirm>
                    <url path="lowstocknotification/alert/massSend"/>
                    <type>send</type>
                    <label translate="true">Send Email</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="lowstocknotification_alert_columns">
        <settings>
            <editorConfig>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="lowstocknotification/alert/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
                <param name="indexField" xsi:type="string">alert_id</param>
                <param name="enabled" xsi:type="boolean">false</param>
                <param name="selectProvider" xsi:type="string">lowstocknotification_alert_listing.lowstocknotification_alert_listing.lowstocknotification_alert_columns.ids</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">lowstocknotification_alert_listing.lowstocknotification_alert_listing.lowstocknotification_alert_columns.actions</item>
                    <item name="target" xsi:type="string">applyAction</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">view</item>
                        <item name="1" xsi:type="string">${ $.$data.rowIndex }</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>alert_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="alert_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="product_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Product ID</label>
            </settings>
        </column>
        <column name="product_name" class="Panth\LowStockNotification\Ui\Component\Listing\Column\ProductName">
            <settings>
                <filter>text</filter>
                <label translate="true">Product Name</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="email">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>
        <column name="customer_name" class="Panth\LowStockNotification\Ui\Component\Listing\Column\CustomerName">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Name</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="customer_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Customer ID</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Panth\LowStockNotification\Model\Source\Status"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <column name="sent_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Sent At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\LowStockNotification\Ui\Component\Listing\Column\AlertActions">
            <settings>
                <indexField>alert_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>107</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
