$customer = $block->getCustomer();
?>

<div class="admin__page-section" style="margin-bottom: 2rem;">
    <div class="admin__page-section-title" style="display:flex; justify-content:space-between; align-items:center;">
        <span class="title"><?= $block->escapeHtml(__('Stock Alert #%1', $alert->getId())) ?></span>
        <div class="page-actions-buttons" style="display:flex; gap:0.5rem;">
            <button type="button" class="action-default scalable back"
                    onclick="setLocation('<?= $block->escapeUrl($block->getBackUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Back')) ?></span>
            </button>
            <?php if ($block->canSendEmail()): ?>
            <button type="button" class="action-default scalable save primary"
                    onclick="confirmSetLocation('<?= $block->escapeJs(__('Are you sure you want to send this alert email?')) ?>', '<?= $block->escapeUrl($block->getSendUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Send Email')) ?></span>
            </button>
            <?php endif; ?>
            <button type="button" class="action-default scalable delete"
                    onclick="confirmSetLocation('<?= $block->escapeJs(__('Are you sure you want to delete this alert?')) ?>', '<?= $block->escapeUrl($block->getDeleteUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Delete')) ?></span>
            </button>
        </div>
    </div>
    <div class="admin__page-section-content">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem;">

            <!-- Alert Details -->
            <fieldset class="admin__fieldset">
                <legend class="admin__legend"><span><?= $block->escapeHtml(__('Alert Information')) ?></span></legend>
                <br/>
                <table class="admin__table-secondary">
                    <tr>
                        <th><?= $block->escapeHtml(__('Alert ID')) ?></th>
                        <td>#<?= $block->escapeHtml($alert->getId()) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Status')) ?></th>
                        <td>
                            <?php
                            $statusClass = $block->getStatusClass($alert->getStatus());
                            $statusLabel = $block->getStatusLabel($alert->getStatus());
                            ?>
                            <span class="<?= $block->escapeHtmlAttr($statusClass) ?>"><span><?= $block->escapeHtml($statusLabel) ?></span></span>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Customer Email')) ?></th>
                        <td><a href="mailto:<?= $block->escapeHtmlAttr($alert->getEmail()) ?>"><?= $block->escapeHtml($alert->getEmail()) ?></a></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Customer')) ?></th>
                        <td>
                            <?php if ($alert->getCustomerId()): ?>
                                <?= $block->escapeHtml(__('Registered (ID: %1)', $alert->getCustomerId())) ?>
                                <?php if ($customer): ?>
                                    — <?= $block->escapeHtml($customer->getFirstname() . ' ' . $customer->getLastname()) ?>
                                <?php endif; ?>
                            <?php else: ?>
                                <?= $block->escapeHtml(__('Guest')) ?>
                            <?php endif; ?>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Store ID')) ?></th>
                        <td><?= $block->escapeHtml($alert->getStoreId()) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Created At')) ?></th>
                        <td><?= $block->escapeHtml($block->formatDate($alert->getCreatedAt(), \IntlDateFormatter::MEDIUM, true)) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Sent At')) ?></th>
                        <td><?= $alert->getSentAt() ? $block->escapeHtml($block->formatDate($alert->getSentAt(), \IntlDateFormatter::MEDIUM, true)) : '<em>' . $block->escapeHtml(__('Not sent yet')) . '</em>' ?></td>
                    </tr>
                </table>
            </fieldset>

            <!-- Product & Stock Details -->
            <fieldset class="admin__fieldset">
                <legend class="admin__legend"><span><?= $block->escapeHtml(__('Product & Stock Details')) ?></span></legend>
                <br/>
                <?php if ($product): ?>
                <table class="admin__table-secondary">
                    <tr>
                        <th><?= $block->escapeHtml(__('Product')) ?></th>
                        <td>
                            <a href="<?= $block->escapeUrl($block->getUrl('catalog/product/edit', ['id' => $product->getId()])) ?>">
                                <?= $block->escapeHtml($product->getName()) ?>
                            </a>
                            <br/><small style="color:#999;">ID: <?= $block->escapeHtml($product->getId()) ?> | SKU: <?= $block->escapeHtml($product->getSku()) ?> | <?= $block->escapeHtml(ucfirst($product->getTypeId())) ?></small>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Price')) ?></th>
                        <td><strong><?= $block->escapeHtml($block->formatPrice($product->getPrice())) ?></strong></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Stock Status')) ?></th>
                        <td>
                            <?php
                            $stockItem = $product->getExtensionAttributes()->getStockItem();
                            $isInStock = $stockItem ? $stockItem->getIsInStock() : false;
                            ?>
                            <?php if ($isInStock): ?>
                                <span class="grid-severity-notice"><span><?= $block->escapeHtml(__('In Stock')) ?></span></span>
                            <?php else: ?>
                                <span class="grid-severity-critical"><span><?= $block->escapeHtml(__('Out of Stock')) ?></span></span>
                            <?php endif; ?>
                        </td>
                    </tr>
                    <?php if ($stockItem): ?>
                    <tr>
                        <th><?= $block->escapeHtml(__('Quantity')) ?></th>
                        <td><strong style="font-size:1.25em;"><?= $block->escapeHtml(number_format($stockItem->getQty(), 0)) ?></strong></td>
                    </tr>
                    <?php endif; ?>
                </table>

                <!-- Stock Status Message -->
                <?php if ($isInStock): ?>
                <div class="message message-success" style="margin-top:1.5rem;">
                    <?= $block->escapeHtml(__('Product is back in stock! The product is now available. You can send an email to notify the customer.')) ?>
                </div>
                <?php else: ?>
                <div class="message message-warning" style="margin-top:1.5rem;">
                    <?= $block->escapeHtml(__('Product is currently out of stock. The customer will be notified once the product becomes available again.')) ?>
                </div>
                <?php endif; ?>

                <?php else: ?>
                <div class="message message-warning">
                    <?= $block->escapeHtml(__('Product not found or has been deleted.')) ?>
                </div>
                <?php endif; ?>
            </fieldset>
        </div>
    </div>
</div>
