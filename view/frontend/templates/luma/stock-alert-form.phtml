<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';
    var uid = '<?= $escaper->escapeJs($uid) ?>';
    var productId = <?= (int)$productId ?>;
    var isLoggedIn = false;
    var customerEmail = '';

    // Detect logged-in customer via Magento localStorage (FPC compatible)
    try {
        var sections = JSON.parse(localStorage.getItem('mage-cache-storage') || '{}');
        if (sections.customer && sections.customer.firstname) {
            isLoggedIn = true;
            customerEmail = sections.customer.email || '';
            var guestFields = document.getElementById(uid + '-guest-fields');
            var loggedMsg = document.getElementById(uid + '-logged-msg');
            var loggedEmailEl = document.getElementById(uid + '-logged-email');
            if (guestFields) guestFields.style.display = 'none';
            if (loggedMsg && customerEmail) {
                loggedMsg.style.display = '';
                if (loggedEmailEl) loggedEmailEl.textContent = customerEmail;
            }
        }
    } catch(e) {}
    var formEl = document.getElementById(uid + '-form');
    var subscribedEl = document.getElementById(uid + '-subscribed');
    var toast = document.getElementById(uid + '-toast');
    var btn = document.getElementById(uid + '-btn');
    var form = document.getElementById(uid + '-subscribe-form');
    var unsubBtn = document.getElementById(uid + '-unsub');
    var toastTimer;

    function getFormKey() {
        var m = document.cookie.match(/form_key=([^;]+)/);
        if (m) return m[1];
        var el = document.querySelector('input[name="form_key"]');
        return el ? el.value : '';
    }

    function showToast(msg, type) {
        if (toastTimer) clearTimeout(toastTimer);
        toast.className = 'sa-toast visible ' + type;
        toast.querySelector('.sa-toast-msg').textContent = msg;
        toast.querySelector('.sa-toast-ok').style.display = type === 'success' ? '' : 'none';
        toast.querySelector('.sa-toast-err').style.display = type === 'error' ? '' : 'none';
        toastTimer = setTimeout(function() { toast.className = 'sa-toast'; }, 5000);
    }

    toast.querySelector('.close').addEventListener('click', function() { toast.className = 'sa-toast'; });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var fd = new FormData();
        fd.append('product_id', productId);
        fd.append('form_key', getFormKey());
        if (!isLoggedIn) {
            var name = document.getElementById(uid + '-name');
            var email = document.getElementById(uid + '-email');
            if (name) fd.append('customer_name', name.value);
            if (email) fd.append('email', email.value);
        }
        btn.disabled = true;
        btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Subscribing...')) ?>';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $escaper->escapeJs($block->getSubscribeUrl()) ?>');
        xhr.withCredentials = true;
        xhr.onload = function() {
            try {
                var data = JSON.parse(xhr.responseText);
                if (data.success) {
                    showToast(data.message || '<?= $escaper->escapeJs(__('Subscribed!')) ?>', 'success');
                    formEl.style.display = 'none';
                    subscribedEl.style.display = '';
                } else {
                    showToast(data.message || '<?= $escaper->escapeJs(__('Failed')) ?>', 'error');
                }
            } catch(ex) { showToast('<?= $escaper->escapeJs(__('An error occurred.')) ?>', 'error'); }
            btn.disabled = false;
            btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Notify Me When Available')) ?>';
        };
        xhr.onerror = function() {
            showToast('<?= $escaper->escapeJs(__('An error occurred.')) ?>', 'error');
            btn.disabled = false;
            btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Notify Me When Available')) ?>';
        };
        xhr.send(fd);
    });

    if (unsubBtn) {
        unsubBtn.addEventListener('click', function() {
            var fd = new FormData();
            fd.append('product_id', productId);
            fd.append('form_key', getFormKey());
            unsubBtn.textContent = '<?= $escaper->escapeJs(__('Removing...')) ?>';
            unsubBtn.disabled = true;

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '<?= $escaper->escapeJs($block->getUnsubscribeUrl()) ?>');
            xhr.withCredentials = true;
            xhr.onload = function() {
                subscribedEl.style.display = 'none';
                formEl.style.display = '';
                unsubBtn.textContent = '<?= $escaper->escapeJs(__('Remove')) ?>';
                unsubBtn.disabled = false;
            };
            xhr.onerror = function() { unsubBtn.textContent = '<?= $escaper->escapeJs(__('Remove')) ?>'; unsubBtn.disabled = false; };
            xhr.send(fd);
        });
    }
});
</script>
