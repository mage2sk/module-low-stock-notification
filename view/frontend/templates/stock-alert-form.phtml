<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('stockAlertComponent', (productId, customerEmail, customerName, isLoggedIn) => ({
        productId, email: customerEmail, customerName, isLoggedIn,
        subscribed: false, submitting: false,
        notification: { show: false, message: '', type: 'success' },

        init() {
            // Detect logged-in customer via Magento section data (FPC compatible)
            try {
                const sections = JSON.parse(localStorage.getItem('mage-cache-storage') || '{}');
                if (sections.customer && sections.customer.firstname) {
                    this.isLoggedIn = true;
                    this.customerName = sections.customer.firstname + (sections.customer.lastname ? ' ' + sections.customer.lastname : '');
                    if (sections.customer.email) {
                        this.email = sections.customer.email;
                    }
                }
            } catch (e) {}

            // If logged in but no email from cache, fetch via AJAX
            if (this.isLoggedIn && !this.email) {
                fetch('/customer/section/load/?sections=customer', { credentials: 'include' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.customer && data.customer.email) {
                            this.email = data.customer.email;
                        }
                        if (data.customer && data.customer.firstname && !this.customerName) {
                            this.customerName = data.customer.firstname + (data.customer.lastname ? ' ' + data.customer.lastname : '');
                        }
                    }).catch(() => {});
            }
        },

        async subscribe() {
            if (!this.isLoggedIn && (!this.customerName || !this.customerName.trim()))
                return this.showNotification('<?= $escaper->escapeJs(__('Please enter your name')) ?>', 'error');
            if (!this.isLoggedIn && (!this.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)))
                return this.showNotification('<?= $escaper->escapeJs(__('Please enter a valid email')) ?>', 'error');

            this.submitting = true;
            try {
                const fd = new FormData();
                fd.append('product_id', this.productId);
                if (!this.isLoggedIn) { fd.append('email', this.email); fd.append('customer_name', this.customerName); }
                fd.append('form_key', hyva.getFormKey());
                const data = await (await fetch('<?= $escaper->escapeUrl($block->getSubscribeUrl()) ?>', { method: 'POST', body: fd })).json();
                if (data.success) {
                    this.showNotification(data.message || '<?= $escaper->escapeJs(__('Subscribed!')) ?>', 'success');
                    this.subscribed = true;
                } else this.showNotification(data.message || '<?= $escaper->escapeJs(__('Failed')) ?>', 'error');
            } catch (e) { this.showNotification('<?= $escaper->escapeJs(__('An error occurred.')) ?>', 'error'); }
            finally { this.submitting = false; }
        },

        async unsubscribe() {
            this.submitting = true;
            try {
                const fd = new FormData();
                fd.append('product_id', this.productId);
                if (!this.isLoggedIn) fd.append('email', this.email);
                fd.append('form_key', hyva.getFormKey());
                const data = await (await fetch('<?= $escaper->escapeUrl($block->getUnsubscribeUrl()) ?>', { method: 'POST', body: fd })).json();
                if (data.success) { this.subscribed = false; this.showNotification('<?= $escaper->escapeJs(__('Unsubscribed')) ?>', 'success'); }
                else this.showNotification(data.message || '<?= $escaper->escapeJs(__('Failed')) ?>', 'error');
            } catch (e) { this.showNotification('<?= $escaper->escapeJs(__('An error occurred.')) ?>', 'error'); }
            finally { this.submitting = false; }
        },

        showNotification(message, type) {
            this.notification = { show: true, message, type };
            setTimeout(() => { this.notification.show = false; }, 5000);
        }
    }));
});
</script>
