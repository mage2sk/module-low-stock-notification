<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_LowStockNotification::panth_lowstocknotification" title="Stock Alerts" sortOrder="300">
                    <resource id="Panth_LowStockNotification::dashboard" title="Dashboard" sortOrder="10"/>
                    <resource id="Panth_LowStockNotification::alerts" title="Manage Alerts" sortOrder="20">
                        <resource id="Panth_LowStockNotification::alert_view" title="View Alert" sortOrder="10"/>
                        <resource id="Panth_LowStockNotification::alert_delete" title="Delete Alert" sortOrder="20"/>
                        <resource id="Panth_LowStockNotification::alert_send" title="Send Alert Email" sortOrder="30"/>
                    </resource>
                    <resource id="Panth_LowStockNotification::config" title="Configuration" sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
